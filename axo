#!/usr/bin/env bash

cmd="$1"
shift
pkgs=("$@")

AXO_ROOT="/etc/nixos/axo"
CONFIG="$AXO_ROOT/config"
DB="$AXO_ROOT/packages.db"
TARGET="$AXO_ROOT/axo.nix"

case "$cmd" in
install)
  for pkg in "${pkgs[@]}"; do
    entry=$(grep -im1 "^$pkg|" "$DB")

    if [ -n "$entry" ]; then
      full_attr=$(echo "$entry" | cut -d'|' -f2)
      echo "Installing $pkg..."

      mkdir -p "$CONFIG"

      if ! grep -Fxq "$full_attr" "$CONFIG/axo.txt" 2>/dev/null; then
        echo "$full_attr" >>"$CONFIG/axo.txt"
      fi
    else
      echo "Package '$pkg' not found!"
    fi
  done

  {
    cat "$CONFIG/header1.txt"
    cat "$CONFIG/header2.txt"
    cat "$CONFIG/header3.txt"
    cat "$CONFIG/axo.txt"
    cat "$CONFIG/footer.txt"
  } | sudo tee "$TARGET" >/dev/null

  sudo nixos-rebuild switch
  echo "Install complete!"
  ;;

uninstall)
  for pkg in "${pkgs[@]}"; do
    entry=$(grep -im1 "^$pkg|" "$DB")

    if [ -n "$entry" ]; then
      full_attr=$(echo "$entry" | cut -d'|' -f2)
    else
      full_attr="$pkg"
    fi

    if grep -Fxq "$full_attr" "$CONFIG/axo.txt" 2>/dev/null; then
      echo "Uninstalling $pkg..."
      sed -i "\|^$full_attr$|d" "$CONFIG/axo.txt"
    else
      echo "Package '$pkg' is not installed!"
    fi
  done

  {
    cat "$CONFIG/header1.txt"
    cat "$CONFIG/header2.txt"
    cat "$CONFIG/header3.txt"
    cat "$CONFIG/axo.txt"
    cat "$CONFIG/footer.txt"
  } | sudo tee "$TARGET" >/dev/null

  sudo nixos-rebuild switch
  echo "Uninstall complete!"
  ;;

list)
  while IFS= read -r line; do
    mapped=$(grep -m1 "|$line$" "$DB" | cut -d'|' -f1)
    if [ -n "$mapped" ]; then
      echo "$mapped"
    else
      echo "$line"
    fi
  done <"$CONFIG/axo.txt"
  ;;

update-db)
  echo "This may take a while..."

  TERM=dumb nix search nixpkgs '^' 2>/dev/null |
    sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g' |
    awk '
        /^\*/ {
            attr = $2

            sub(/^legacyPackages\.[^.]+\./, "", attr)

            n = split(attr, parts, ".")
            short = parts[n]

            print short "|" attr
        }' >"$DB"

  echo "Database has been updated!"
  ;;

enable)
  for pkg in "${pkgs[@]}"; do
    if grep -q "$pkg" "$CONFIG/axo.txt"; then
      echo "Enabling $pkg!"
      echo "programs.$pkg.enable = true;" >>"$CONFIG/header2.txt"
    else
      echo "Package '$pkg' is not installed! Skipping."
    fi
  done

  {
    cat "$CONFIG/header1.txt"
    cat "$CONFIG/header2.txt"
    cat "$CONFIG/header3.txt"
    cat "$CONFIG/axo.txt"
    cat "$CONFIG/footer.txt"
  } | sudo tee "$TARGET" >/dev/null

  sudo nixos-rebuild switch
  echo "Enable complete!"
  ;;

disable)
  for pkg in "${pkgs[@]}"; do
    if grep -q "$pkg" "$CONFIG/header2.txt"; then
      echo "Disabling $pkg!"
      sed -i "/programs.$pkg.enable = true;/d" "$CONFIG/header2.txt"
    else
      echo "Package '$pkg' isn't enabled!"
    fi
  done

  {
    cat "$CONFIG/header1.txt"
    cat "$CONFIG/header2.txt"
    cat "$CONFIG/header3.txt"
    cat "$CONFIG/axo.txt"
    cat "$CONFIG/footer.txt"
  } | sudo tee "$TARGET" >/dev/null

  sudo nixos-rebuild switch
  echo "Disable complete!"
  ;;

*)
  echo "Axo currently only supports these terms:

install: Installs packages from Nixpkgs (multi-package supported)
uninstall: Removes installed packages

enable: Enables NixOS programs
disable: Disables NixOS programs

list: Lists installed packages
update-db: Updates package database

Usage examples:
  axo install neovim git kitty
  axo uninstall firefox vlc
  axo enable hyprland waybar

Note: This system is still experimental and may contain bugs."
  ;;
esac
